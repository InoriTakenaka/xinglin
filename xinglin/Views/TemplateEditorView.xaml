<UserControl x:Class="xinglin.Views.TemplateEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:xinglin.Views"
             xmlns:vm="clr-namespace:xinglin.ViewModels"
             xmlns:models="clr-namespace:xinglin.Models.CoreEntities"
             xmlns:utils="clr-namespace:xinglin.Utils">
    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="10" ShadowDepth="5" Color="#80000000"/>
        <utils:DoubleToScaleConverter x:Key="DoubleToScaleConverter"/>
        <utils:MillimeterToPixelConverter x:Key="MillimeterToPixelConverter"/>
        <utils:ZoomToBorderThicknessConverter x:Key="ZoomToBorderThicknessConverter"/>
        <utils:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <utils:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:ControlTemplateSelector x:Key="ControlTemplateSelector">
            <local:ControlTemplateSelector.LabelTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <TextBlock Text="{Binding Text, FallbackValue='标签'}" 
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Margin="5"
                                   FontFamily="{Binding FontFamily}" 
                                   FontSize="{Binding FontSize}" 
                                   FontWeight="{Binding IsBold, Converter={StaticResource BoolToFontWeightConverter}}" 
                                   FontStyle="{Binding IsItalic, Converter={StaticResource BoolToFontStyleConverter}}"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.LabelTemplate>
            <local:ControlTemplateSelector.TextBoxTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <TextBox Text="{Binding Text, FallbackValue='文本框'}" 
                                 HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
                                 Margin="5"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 FontFamily="{Binding FontFamily}" 
                                 FontSize="{Binding FontSize}"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.TextBoxTemplate>
            <local:ControlTemplateSelector.ComboBoxTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <ComboBox Text="{Binding SelectedValue, FallbackValue='下拉框'}" 
                                  HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
                                  Margin="5"
                                  IsReadOnly="True"
                                  IsEnabled="False"
                                  IsHitTestVisible="False"
                                  FontFamily="{Binding FontFamily}" 
                                  FontSize="{Binding FontSize}"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.ComboBoxTemplate>
            <local:ControlTemplateSelector.CheckBoxTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"
                                    IsHitTestVisible="False">
                            <CheckBox IsChecked="{Binding IsChecked}" IsEnabled="False"/>
                            <TextBlock Text="{Binding Text, FallbackValue='复选框'}" Margin="5,0,0,0"
                                       FontFamily="{Binding FontFamily}" 
                                       FontSize="{Binding FontSize}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.CheckBoxTemplate>
            <local:ControlTemplateSelector.RadioButtonTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"
                                    IsHitTestVisible="False">
                            <RadioButton IsChecked="{Binding IsChecked}" IsEnabled="False"/>
                            <TextBlock Text="{Binding Text, FallbackValue='单选按钮'}" Margin="5,0,0,0"
                                       FontFamily="{Binding FontFamily}" 
                                       FontSize="{Binding FontSize}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.RadioButtonTemplate>
            <local:ControlTemplateSelector.DateTimePickerTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <TextBox Text="{Binding Text, FallbackValue='日期时间选择器'}" 
                                 HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
                                 Margin="5"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 FontFamily="{Binding FontFamily}" 
                                 FontSize="{Binding FontSize}"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.DateTimePickerTemplate>
            <local:ControlTemplateSelector.TableTemplate>
                <DataTemplate DataType="{x:Type models:TableElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="配置表格" Click="ConfigureTable_Click"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel Width="{Binding Width}" Height="{Binding Height}" Margin="2">
                            <!-- 表头 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                <Border Width="50" BorderBrush="Black" BorderThickness="1" Background="#F0F0F0">
                                    <TextBlock Text="行号" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Columns}" HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TableColumn}">
                                            <Border Width="{Binding Width}" BorderBrush="Black" BorderThickness="1" Background="#F0F0F0">
                                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <!-- 数据行 -->
                            <ItemsControl ItemsSource="{Binding Rows}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TableRow}">
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                            <Border Width="50" BorderBrush="Black" BorderThickness="1" Background="White">
                                                <TextBlock Text="{Binding RowIndex}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                            </Border>
                                            <ItemsControl ItemsSource="{Binding Path=DataContext.Columns, RelativeSource={RelativeSource AncestorType={x:Type Border}}}" HorizontalAlignment="Stretch">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:TableColumn}">
                                                        <Border Width="{Binding Width}" BorderBrush="Black" BorderThickness="1" Background="White">
                                                            <TextBlock Text="{Binding Path=DataContext.CellValues[Name], RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Margin="2"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.TableTemplate>
            <local:ControlTemplateSelector.ImageTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <TextBlock Text="图片" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.ImageTemplate>
            <local:ControlTemplateSelector.LineTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <Line X1="0" Y1="0" X2="{Binding Width}" Y2="{Binding Height}" Stroke="Black" StrokeThickness="1"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.LineTemplate>
            <local:ControlTemplateSelector.RectangleTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <Rectangle MinWidth="{Binding Width}" MinHeight="{Binding Height}" Stroke="Black" StrokeThickness="1" Fill="Transparent"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.RectangleTemplate>
            <local:ControlTemplateSelector.DefaultControlTemplate>
                <DataTemplate DataType="{x:Type models:ControlElement}">
                    <Border MinWidth="{Binding Width}" MinHeight="{Binding Height}" 
                            Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}" 
                            BorderThickness="2"
                            MouseDown="ControlElement_MouseDown"
                            MouseMove="ControlElement_MouseMove"
                            MouseUp="ControlElement_MouseUp"
                            Tag="{Binding}">
                        <TextBlock Text="{Binding DisplayName}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </local:ControlTemplateSelector.DefaultControlTemplate>
        </local:ControlTemplateSelector>
    </UserControl.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <ToolBar Grid.Row="0">
            <Button Command="{Binding CreateNewTemplateCommand}" Content="新建"/>
            <Button Command="{Binding SaveTemplateCommand}" Content="保存"/>
            <Button Command="{Binding LoadDefaultTemplateCommand}" Content="加载默认模板"/>
            <Button Command="{Binding PreviewTemplateCommand}" Content="预览"/>
            <Separator/>
            <Label Content="纸张大小:"/>
            <ComboBox Width="120" SelectedValue="{Binding PaperSize, Mode=TwoWay}" SelectedValuePath="Tag" SelectionChanged="PaperSize_SelectionChanged">
                <ComboBoxItem Content="A4 (210x297)" Tag="A4"/>
                <ComboBoxItem Content="A5 (148x210)" Tag="A5"/>
                <ComboBoxItem Content="A3 (297x420)" Tag="A3"/>
            </ComboBox>
            <Separator/>
            <Label Content="缩放:"/>
            <Button Command="{Binding ZoomOutCommand}" Content="-" Width="30"/>
            <Slider Width="100" Minimum="25" Maximum="200" Value="{Binding ZoomLevel, Mode=TwoWay}"/>
            <Button Command="{Binding ZoomInCommand}" Content="+" Width="30"/>
            <Button Command="{Binding ResetZoomCommand}" Content="100%" Width="60"/>
        </ToolBar>
        
        <!-- 主编辑区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧工具箱 -->
            <local:ToolboxView Grid.Column="0"/>
            
            <!-- 中间编辑区 -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 画布容器 -->
                        <Border BorderBrush="Black" BorderThickness="{Binding ZoomLevel, Converter={StaticResource ZoomToBorderThicknessConverter}}" Background="#F0F0F0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Effect="{StaticResource DropShadowEffect}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding ZoomLevel, Converter={StaticResource DoubleToScaleConverter}}" 
                                               ScaleY="{Binding ZoomLevel, Converter={StaticResource DoubleToScaleConverter}}"/>
                            </Border.RenderTransform>
                            <Canvas x:Name="EditorCanvas" Background="White"
                                    Width="{Binding CurrentTemplate.Layout.PaperWidth, Converter={StaticResource MillimeterToPixelConverter}}"
                                    Height="{Binding CurrentTemplate.Layout.PaperHeight, Converter={StaticResource MillimeterToPixelConverter}}"
                                    AllowDrop="True"
                                    DragEnter="EditorCanvas_DragEnter"
                                    DragOver="EditorCanvas_DragOver"
                                    DragLeave="EditorCanvas_DragLeave"
                                    Drop="EditorCanvas_Drop"
                                    MouseDown="EditorCanvas_MouseDown">
                                <ItemsControl x:Name="EditorItemsControl" ItemsSource="{Binding CurrentTemplate.Layout.EditableElements}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplateSelector>
                                        <StaticResource ResourceKey="ControlTemplateSelector"/>
                                    </ItemsControl.ItemTemplateSelector>
                                </ItemsControl>
                            </Canvas>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>
            
            <!-- 右侧属性编辑器 -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Background="#F5F5F5"
                    Visibility="{Binding SelectedControl, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="属性编辑器" FontWeight="Bold" Margin="10" Grid.Column="0"/>
                        <Button Grid.Column="1" Content="▼" Width="20" Height="20" Margin="5" 
                                Click="TogglePropertiesPanel_Click" x:Name="TogglePropertiesButton"/>
                    </Grid>
                    <TextBlock Margin="10">
                        <Run Text="选中控件: "/>
                        <Run Text="{Binding SelectedControl.DisplayName}"/>
                    </TextBlock>
                    
                    <StackPanel x:Name="PropertiesContentPanel">
                        <!-- 通用属性 -->
                        <Expander Header="通用属性" Margin="10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="名称:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.DisplayName, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文本内容:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.Text, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="选中值:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.SelectedValue, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="X坐标:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.X, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Y坐标:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.Y, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="宽度:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.Width, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="高度:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.Height, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="绑定路径:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.BindingPath, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- 字体属性 -->
                        <Expander Header="字体属性" Margin="10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="字体:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" SelectedItem="{Binding SelectedControl.FontFamily, Mode=TwoWay}">
                                        <ComboBoxItem>Microsoft YaHei</ComboBoxItem>
                                        <ComboBoxItem>SimSun</ComboBoxItem>
                                        <ComboBoxItem>SimHei</ComboBoxItem>
                                        <ComboBoxItem>Arial</ComboBoxItem>
                                        <ComboBoxItem>Times New Roman</ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="字号:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedControl.FontSize, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="样式:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding SelectedControl.IsBold, Mode=TwoWay}" Content="粗体" Margin="0,0,10,0"/>
                                        <CheckBox IsChecked="{Binding SelectedControl.IsItalic, Mode=TwoWay}" Content="斜体" Margin="0,0,10,0"/>
                                        <CheckBox IsChecked="{Binding SelectedControl.IsUnderline, Mode=TwoWay}" Content="下划线"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="状态:" Grid.Column="0" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding SelectedControl.IsChecked, Mode=TwoWay}" Content="选中"/>
                                </Grid>
                            </StackPanel>
                        </Expander>
                        
                        <!-- 控件类型特定属性 -->
                        <Expander Header="特定属性" Margin="10">
                            <StackPanel x:Name="SpecificPropertiesPanel">
                                <!-- 特定属性将根据控件类型动态生成 -->
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2">
            <TextBlock Text="就绪"/>
        </StatusBar>
    </Grid>
</UserControl>