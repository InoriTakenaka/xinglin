<Window x:Class="xinglin.Views.TableConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:xinglin.Models.CoreEntities"
        Title="表格配置"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="表格配置" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <!-- 内容区域 -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- 列配置标签页 -->
            <TabItem Header="列配置">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="列列表" FontSize="14" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="添加列" Click="AddColumn_Click" Margin="10,0,0,0"/>
                    </Grid>
                    <DataGrid x:Name="ColumnsDataGrid" Margin="10" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="列名" Binding="{Binding Name, Mode=TwoWay}" Width="100"/>
                            <DataGridTextColumn Header="宽度" Binding="{Binding Width, Mode=TwoWay}" Width="80"/>
                            <DataGridTextColumn Header="绑定路径" Binding="{Binding BindingPath, Mode=TwoWay}" Width="150"/>
                            <DataGridTextColumn Header="默认值" Binding="{Binding DefaultValue, Mode=TwoWay}" Width="100"/>
                            <DataGridComboBoxColumn Header="控件类型" Width="100">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="models:ControlType">
                                        <models:ControlType>Label</models:ControlType>
                                        <models:ControlType>ComboBox</models:ControlType>
                                        <models:ControlType>CheckBox</models:ControlType>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                                <DataGridComboBoxColumn.SelectedItemBinding>
                                    <Binding Path="ControlType" Mode="TwoWay"/>
                                </DataGridComboBoxColumn.SelectedItemBinding>
                            </DataGridComboBoxColumn>
                            <DataGridCheckBoxColumn Header="可修改" Binding="{Binding IsEditable, Mode=TwoWay}" Width="80"/>
                            <DataGridTemplateColumn Header="操作" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="删除" Click="DeleteColumn_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- 行配置标签页 -->
            <TabItem Header="行配置">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="行列表" FontSize="14" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="添加行" Click="AddRow_Click" Margin="10,0,0,0"/>
                        <Button Grid.Column="2" Content="删除行" Click="DeleteRow_Click" Margin="10,0,0,0"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="行数: " VerticalAlignment="Center"/>
                            <TextBox x:Name="RowCountTextBox" Width="50" Text="{Binding RowCount, Mode=TwoWay}"/>
                            <Button Content="设置" Click="SetRowCount_Click" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid x:Name="RowsDataGrid" Margin="10" AutoGenerateColumns="False" CanUserAddRows="False">
                        <!-- 列将在代码中动态生成 -->
                    </DataGrid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10" HorizontalAlignment="Right">
            <Button Content="确定" Click="Ok_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="取消" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>