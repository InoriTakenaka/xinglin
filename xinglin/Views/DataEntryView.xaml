<UserControl x:Class="xinglin.Views.DataEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:xinglin.Views"
             xmlns:vm="clr-namespace:xinglin.ViewModels">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Grid.ColumnSpan="2">
            <Button Content="加载数据" Command="{Binding LoadDataAsyncCommand}"/>
            <Button Content="保存数据" Command="{Binding SaveDataAsyncCommand}"/>
            <Button Command="{Binding GenerateReportCommand}" Content="生成报告" IsEnabled="{Binding IsValid}"/>
            <Button Command="{Binding ClearMessagesCommand}" Content="清除消息"/>
            <Button Content="打印" Command="{Binding PrintCommand}"/>
            <Separator/>
            <ProgressBar IsIndeterminate="{Binding IsLoading}" Width="100" Height="16" VerticalAlignment="Center"/>
            <TextBlock Text="加载中..." Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="5,0"/>
        </ToolBar>
        
        <!-- 数据录入区 -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer>
                <StackPanel x:Name="DataEntryPanel">
                    <!-- 控件将通过代码动态添加 -->
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- 右侧预览面板 -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1,0,0,0">
            <StackPanel>
                <TextBlock Text="预览" FontWeight="Bold" FontSize="16" Margin="10"/>
                <Border BorderBrush="Gray" BorderThickness="1" Margin="10">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="报告预览将显示在这里" Margin="10" TextWrapping="Wrap"/>
                            <TextBlock Text="生成报告后，您可以在这里看到报告的预览效果。" Margin="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Button Content="刷新预览" Margin="10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- 验证状态 -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Text="验证状态: " Margin="5,0"/>
                <TextBlock Text="有效" Foreground="Green" FontWeight="Bold" Margin="5,0" Visibility="{Binding IsValid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="无效" Foreground="Red" FontWeight="Bold" Margin="5,0" Visibility="{Binding IsValid, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Reverse}"/>
                <TextBlock Text=" | " Margin="5,0"/>
                <TextBlock Text="{Binding ValidationErrors.Count, StringFormat='错误数: {0}'}" Margin="5,0"/>
            </StackPanel>
        </StatusBar>
        
        <!-- 错误消息显示 -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="Red" BorderThickness="1" Background="#FFF5F5F5" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10">
                    <TextBlock Text="错误:" FontWeight="Bold" Foreground="Red" Margin="0,0,5,0"/>
                    <Button Command="{Binding ClearMessagesCommand}" Content="×" Width="20" Height="20" Padding="0" HorizontalAlignment="Right"/>
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Margin="10" Foreground="Red" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- 成功消息显示 -->
        <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="Green" BorderThickness="1" Background="#F5FFF5" Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10">
                    <TextBlock Text="成功:" FontWeight="Bold" Foreground="Green" Margin="0,0,5,0"/>
                    <Button Command="{Binding ClearMessagesCommand}" Content="×" Width="20" Height="20" Padding="0" HorizontalAlignment="Right"/>
                </StackPanel>
                <TextBlock Text="{Binding SuccessMessage}" Margin="10" Foreground="Green" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>